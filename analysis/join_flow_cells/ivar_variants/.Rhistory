library('tidyverse')
library('openxlsx')
library('ggbeeswarm')
library('patchwork')
library('ggplot2')
library('reshape2')
library("biclust")
setwd('/Users/bbernal/Documents/covid_work/join_flow_cells/ivar_variants/')
ivar_files <- list.files(pattern = "\\.tsv$")
sample <- ivar_files[0:96]
all_mutation <- list()
for(i in sample){
print(i)
variant <- paste('sample_', strsplit(strsplit(i, '_')[[1]][3],  '.', fixed = TRUE)[[1]][1], sep = '')
df <- read.table(i, h=TRUE,sep="\t")
all_mutation[[variant]] <- df$POS}
#generation of binary matrix
mut_matrix <- t(splitstackshape:::charMat(listOfValues = all_mutation, fill = 0L))
colnames(mut_matrix) <- names(all_mutation)
head(mut_matrix)
mut_matrix <- mut_matrix[order(rowSums(mut_matrix),decreasing=T),] #sort by position with more mutations
mut_matrix.t <- t(mut_matrix) #transpose
head(mut_matrix)
head(mut_matrix.t)
#biclustering - ordenar filas y columnas
##BICLUST APPROACH
mut_matrix.clust <- biclust(x = mut_matrix, method=BCBimax())
heatmapBC(x = mut_matrix., bicResult = mut_matrix.clust)
drawHeatmap2(x = mut_matrix, bicResult = mut_matrix.clust, number = 100)
heatmapBC(x = mut_matrix.t, bicResult = mut_matrix.clust)
drawHeatmap2(x = mut_matrix, bicResult = mut_matrix.clust, number = 100)
heatmapBC(x = mut_matrix.t, bicResult = mut_matrix.clust)
heatmapBC(x = mut_matrix.t, bicResult = mut_matrix.clust)
#biclustering - ordenar filas y columnas
##BICLUST APPROACH
mut_matrix.clust <- biclust(x = mut_matrix, method=BCBimax())
#biclustering - ordenar filas y columnas
##BICLUST APPROACH
mut_matrix.clust <- biclust(x = mut_matrix.t, method=BCBimax())
heatmapBC(x = mut_matrix.t, bicResult = mut_matrix.clust)
biclust_hetmap <- heatmapBC(x = mut_matrix.t, bicResult = mut_matrix.clust)
biclust_hetmap
drawHeatmap2(x = mut_matrix.t, bicResult = mut_matrix.clust, number = 100)
heatmapBC(x = mut_matrix.t, bicResult = mut_matrix.clust)
drawHeatmap2(x = mut_matrix.t, bicResult = mut_matrix.clust, number = 100)
##PHEATMAP
library(pheatmap)
#cutree_rows number of clusters the rows are divided into, based on the hierarchical clustering (using cutree), if rows are not clustered, the argument is ignored
pheatmap(mut_matrix.t, cutree_rows = 2, col = c("cadetblue3", "salmon"), fontsize = 5.5)
#HEATMAP R BASE
Heatmap(mut_matrix,
row_names_gp = gpar(fontsize = 7,
col = c("cadetblue3", "salmon")) # Text size for row names
)
