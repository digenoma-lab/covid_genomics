geom_text_repel(data = subset(all_results, value < 20000 & mut_ivar < 40 & variant == 'Omicron'  & location=='Santiago'),
aes(label = sampleId)) +
geom_point() +
scale_color_manual('', values = col.list$variant) +
theme_minimal()
