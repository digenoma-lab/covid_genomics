geom_point() +
scale_color_manual('', values = col.list$variant) +
theme_minimal()
#samtools_depth
setwd('/Users/bbernal/Documents/covid_work/join_flow_cells/samtools_depth/')
samtools_files <- list.files(pattern = "\\.txt$")
sample <- samtools_files[0:96]
depth <- list()
for(i in sample){
print(i)
#transform name of sample to sample_NN
sample = paste('sample_',
strsplit(strsplit(i, '_')[[1]][3],  '.', fixed = TRUE)[[1]][1],
sep = '')
variant <- substring(sample, 1, nchar(sample)-3)
df <- read.table(i, h=FALSE,sep="\t")
colnames(df) <- c('ref', 'pos', 'depth')
depth[[variant]] <- df}
samtools_results <- lapply(depth, as.data.frame) %>%
bind_rows(.id = "sampleId")
samtools_results <- left_join(samtools_results,all_results[c('sampleId', 'location', 'variant')], by="sampleId")
samtools_results <- samtools_results[,-2]
samtools_results<-samtools_results[!grepl("71",
samtools_results$sample),]
samtools_depth_range <- samtools_results %>%
group_by(sampleId, grp = cut(pos, breaks=pretty(pos, n = 60)), location, variant) %>%
summarise(count = mean(depth))
grid1 <- ggplot(samtools_depth_range , aes(x = grp, y=log(count),
colour = variant)) +
geom_line(aes(group = sampleId), size = 0.3, alpha = 0.8)+
geom_hline(yintercept = log(100),color="red2",
linetype='dotted',size=0.5) +
annotate("text", x = 45, y = log(100), label = "100X Coverage", vjust = -0.5, size=3) +
facet_grid(rows = vars(variant), col = vars(location)) +
scale_color_manual('', values = col.list$variant) +
theme_minimal() + theme(axis.text.x = element_text(angle = 90, hjust = 0.5, size = 5))
grid1
mutations <- ggplot(data=all_results, aes(x=mut_ivar, y=pass_freya, label=sampleId, shape=location, colour = variant)) +
geom_point() +
scale_color_manual('', values = col.list$variant) +
theme_minimal()
